from qutip_qip.circuit import QubitCircuit
import numpy as np

# Load the circuit from QASM file
qc = QubitCircuit.from_qasm("deutsch-jozsa.qasm")

# Save the circuit to QASM file
qc.to_qasm("deutsch-jozsa-qutip.qasm")

# Example of adding a gate with arguments
pi = np.pi
q = QubitCircuit(1)
q.add_gate("RZ", targets=0, arg_values=pi / 2, style={"showarg": True})
q.draw()
```